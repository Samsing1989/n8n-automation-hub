        "jsCode": "const message = $('Receive User Message').item.json.message;\nconst chatId = message.chat.id;\nconst text = message.text || '';\n\n// Повертаємо дані для наступних нод\nreturn [{\n  json: {\n    chatId: chatId,\n    userText: text,\n    isClear: text.trim().toLowerCase() === '/clear'\n  }\n}];\n"
