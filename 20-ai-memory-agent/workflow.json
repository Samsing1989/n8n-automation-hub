    {
      "parameters": {
        "jsCode": "// Отримуємо всі рядки з Google Sheets\nconst allItems = $input.all();\nconst chatId = $('Extract Message Data').item.json.chatId;\nconst userText = $('Extract Message Data').item.json.userText;\n\n// Беремо останні 10 повідомлень і реверсуємо\nconst rows = allItems\n.map(item => item.json)\n.filter(row => String(row.chat_id) === String(chatId))\n.filter(row => row.role === 'user' || row.role === 'assistant') // фільтр невалідних\n.filter(row => row.content && row.content.trim() !== '') // фільтр порожніх\n.slice(0, 10)\n.reverse();\n\n// Формуємо messages array для Groq API\nconst messages = rows.map(row => ({\nrole: row.role,\ncontent: row.content\n}));\n\n// Додаємо нове повідомлення користувача\nmessages.push({ role: 'user', content: userText });\n\nreturn [{ json: {\nchatId: chatId,\nuserText: userText,\nmessages: messages\n}}];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -96,
        144
      ],
      "id": "88ee1f45-f8a9-4829-a94f-33a1e5e93c7e",
      "name": "Format History for AI"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.groq.com/openai/v1/chat/completions",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n\"model\": \"llama-3.3-70b-versatile\",\n\"messages\": {{ JSON.stringify([{ \"role\": \"system\", \"content\": \"Ти корисний AI-асистент. Відповідай чітко та зрозуміло.\" }, ...$json.messages]) }},\n\"temperature\": 0.7,\n\"max_tokens\": 1024\n}\n",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        112,
