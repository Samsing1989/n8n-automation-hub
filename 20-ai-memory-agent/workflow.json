    {
      "parameters": {
        "jsCode": "const response = $input.item.json;\nconst aiReply = response.choices[0].message.content;\nconst chatId = $('Format History for AI').item.json.chatId;\nconst userText = $('Format History for AI').item.json.userText;\n\nreturn [{ json: {\n  chatId: chatId,\n  userText: userText,\n  aiReply: aiReply\n}}];\n"
      },
