      "typeVersion": 4.7,
      "position": [
        -640,
        -352
      ],
      "id": "NODE_READ_AGENCY_METRICS",
      "name": "Read Agency Metrics",
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "YOUR_CREDENTIAL_ID",
          "name": "Google Sheets account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const rows = $input.all();\nconst active = rows.filter(r => r.json['Статус'] === 'В роботі').length;\nconst done = rows.filter(r => r.json['Статус'] === 'Завершено').length;\nconst totalPaid = rows.filter(r => r.json['Статус'] === 'Завершено').reduce((sum, r) => sum + (parseFloat(r.json['Оплата']) || 0), 0);\nreturn [{ json: { active, done, totalPaid, week: new Date().toLocaleDateString('uk-UA') } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -432,
        -352
      ],
      "id": "NODE_BUILD_WEEKLY_REPORT",
      "name": "Build Weekly Report"
    },
    {
      "parameters": {
        "chatId": "YOUR_TELEGRAM_CHAT_ID",
        "text": "=📊 ТИЖНЕВИЙ ЗВІТ\nТиждень: {{ $json.week }}\n🔄 Активних: {{ $json.active }}\n✅ Завершених: {{ $json.done }}\n💰 Зароблено: {{ $json.totalPaid }} грн",
        "additionalFields": {
          "appendAttribution": false
        }
      },
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
