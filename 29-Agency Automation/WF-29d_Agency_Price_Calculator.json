    {
      "parameters": {
        "jsCode": "const text = $input.item.json.message.text.trim();\n\n// Якщо це сам /price — показуємо меню\nif (text === '/price') {\nreturn [{ json: {\nchat_id: $input.item.json.message.chat.id,\ntext: `🤖 *Калькулятор вартості автоматизації*\\n\\nЯкий тип автоматизації вас цікавить?\\n\\n1️⃣ Telegram бот\\n2️⃣ CRM інтеграція\\n3️⃣ E-commerce\\n4️⃣ AI агент\\n5️⃣ Соцмережі\\n6️⃣ Комплексне рішення\\n\\nНапишіть номер або опишіть задачу`\n}}];\n}\n\n// Якщо це вибір (1-6) — показуємо ціну\nconst prices = {\n'1': { name: 'Telegram бот', min: 150, max: 300, days: '3-5' },\n'2': { name: 'CRM інтеграція', min: 200, max: 400, days: '5-7' },\n'3': { name: 'E-commerce', min: 350, max: 700, days: '7-10' },\n'4': { name: 'AI агент', min: 250, max: 500, days: '5-8' },\n'5': { name: 'Соцмережі', min: 150, max: 300, days: '3-5' },\n'6': { name: 'Комплексне рішення', min: 500, max: 1500, days: '14-21' }\n};\n\nconst p = prices[text] || prices['6'];\n\nreturn [{ json: {\nchat_id: $input.item.json.message.chat.id,\ntext: `💰 *Орієнтовна вартість: ${p.name}*\\n\\nВід $${p.min} до $${p.max}\\nТермін: ${p.days} робочих днів\\n\\nДля точного розрахунку напишіть /consult`\n}}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -912,
