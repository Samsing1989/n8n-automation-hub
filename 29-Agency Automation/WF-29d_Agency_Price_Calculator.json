    {
      "parameters": {
        "jsCode": "const chatId = $input.item.json.message.chat.id;\nconst firstName = $input.item.json.message.chat.first_name || 'Клієнт';\n\nreturn [{ json: {\nchat_id: chatId,\ntext: `👋 Привіт, ${firstName}!\\n\\nДля безкоштовної консультації надішли свої дані у форматі:\\n\\n📝 *Ім'я Прізвище*\\n📱 *Телефон*\\n📧 *Email*\\n\\nНаприклад:\\n_Іван Петренко_\\n_+380991234567_\\n_ivan@gmail.com_`\n}}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -912,
        -256
      ],
      "id": "NODE_CALCULATE_CONSULT_PRICE",
      "name": "Calculate Consult Price"
    },
    {
      "parameters": {
        "jsCode": "const text = $input.item.json.message.text.trim();\nconst chatId = $input.item.json.message.chat.id;\nconst lines = text.split('\\n').map(l => l.trim());\n\nconst name = lines[0] || 'Невідомо';\nconst phone = lines[1] || 'Не вказано';\nconst email = lines[2] || 'Не вказано';\nconst date = new Date().toLocaleDateString('uk-UA');\n\nreturn [{ json: {\nchat_id: chatId,\nname: name,\nphone: phone,\nemail: email,\ndate: date,\n// Повідомлення клієнту\nclient_text: `✅ Дякую, ${name}!\\n\\nТвої дані отримані:\\n📱 ${phone}\\n📧 ${email}\\n\\nЯ зв'яжусь з тобою протягом *2 годин*! 🚀`,\n// Сповіщення тобі\nowner_text: `🔥 *НОВИЙ ЛІД НА КОНСУЛЬТАЦІЮ*\\n\\n👤 Ім'я: ${name}\\n📱 Телефон: ${phone}\\n📧 Email: ${email}\\n📅 Дата: ${date}\\n\\nЗателефонуй якнайшвидше!`\n}}];"
      },
      "type": "n8n-nodes-base.code",
