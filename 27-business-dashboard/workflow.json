            { "id": "e6c1b6ca", "leftValue": "={{ $('Fetch CRM Leads').item.json.total }}", "rightValue": 0, "operator": { "type": "number", "operation": "equals" } },
            { "id": "894d9aaa", "leftValue": "={{ $('Fetch Revenue Today').item.json.revenue }}", "rightValue": 50, "operator": { "type": "number", "operation": "gt" } },
            { "id": "cb666f8d", "leftValue": "={{ $('Fetch Active Tickets').item.json.tickets.length }}", "rightValue": 20, "operator": { "type": "number", "operation": "gt" } }
          ],
          "combinator": "or"
        },
        "options": {}
      },
