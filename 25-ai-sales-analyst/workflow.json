        "sendTo": "YOUR_EMAIL",
        "subject": "=Тижневий AI-звіт продажів | {{ $json.week_start }} — {{ $json.week_end }}",
        "message": "=<html><body style=\"font-family:Arial,sans-serif;max-width:700px;margin:0 auto\">\n<h2 style=\"color:#1B4F72\">📊 Тижневий звіт продажів</h2>\n<p style=\"color:#555\">{{ $json.week_start }} — {{ $json.week_end }}</p>\n\n<table style=\"width:100%;border-collapse:collapse;margin:20px 0\">\n<tr style=\"background:#1B4F72;color:white\">\n<th style=\"padding:10px;text-align:left\">Метрика</th>\n<th style=\"padding:10px;text-align:right\">Значення</th>\n</tr>\n<tr>\n<td style=\"padding:8px;border:1px solid #ddd\">🌍 Загальна виручка</td>\n<td style=\"padding:8px;border:1px solid #ddd;text-align:right\">€{{ $json.total_revenue }}</td>\n</tr>\n<tr style=\"background:#f9f9f9\">\n<td style=\"padding:8px;border:1px solid #ddd\">🛒 Кількість замовлень</td>\n<td style=\"padding:8px;border:1px solid #ddd;text-align:right\">{{ $json.total_orders }}</td>\n</tr>\n<tr>\n<td style=\"padding:8px;border:1px solid #ddd\">🏆 Топ продукт</td>\n<td style=\"padding:8px;border:1px solid #ddd;text-align:right\">{{ $json.top_product }}</td>\n</tr>\n</table>\n\n<h3 style=\"color:#1B4F72\">🏆 ТОП-3 продукти</h3>\n<table style=\"width:100%;border-collapse:collapse\">\n<tr style=\"background:#2E86C1;color:white\">\n<th style=\"padding:8px\">Продукт</th>\n<th style=\"padding:8px;text-align:right\">Виручка</th>\n<th style=\"padding:8px;text-align:right\">Кількість</th>\n</tr>\n<tr style=\"background:#f9f9f9\">\n<td style=\"padding:8px;border:1px solid #ddd\">{{ $json.top3[0]?.name || '-' }}</td>\n<td style=\"padding:8px;border:1px solid #ddd;text-align:right\">€{{ $json.top3[0]?.revenue?.toFixed(2) || '0.00' }}</td>\n<td style=\"padding:8px;border:1px solid #ddd;text-align:right\">{{ $json.top3[0]?.qty || 0 }}</td>\n</tr>\n<tr>\n<td style=\"padding:8px;border:1px solid #ddd\">{{ $json.top3[1]?.name || '-' }}</td>\n<td style=\"padding:8px;border:1px solid #ddd;text-align:right\">€{{ $json.top3[1]?.revenue?.toFixed(2) || '0.00' }}</td>\n<td style=\"padding:8px;border:1px solid #ddd;text-align:right\">{{ $json.top3[1]?.qty || 0 }}</td>\n</tr>\n<tr style=\"background:#f9f9f9\">\n<td style=\"padding:8px;border:1px solid #ddd\">{{ $json.top3[2]?.name || '-' }}</td>\n<td style=\"padding:8px;border:1px solid #ddd;text-align:right\">€{{ $json.top3[2]?.revenue?.toFixed(2) || '0.00' }}</td>\n<td style=\"padding:8px;border:1px solid #ddd;text-align:right\">{{ $json.top3[2]?.qty || 0 }}</td>\n</tr>\n</table>\n\n<h3 style=\"color:#1E8449\">🤖 AI Рекомендації</h3>\n<div style=\"background:#f0f8f0;padding:15px;border-left:4px solid #1E8449;border-radius:4px\">\n<pre style=\"white-space:pre-wrap;font-family:Arial\">{{ $json.ai_recommendations }}</pre>\n</div>\n\n<p style=\"color:#888;font-size:12px;margin-top:30px\">\nЗгенеровано автоматично: {{ $json.generated_at }} | n8n Automation\n</p>\n</body></html>",
        "options": {}
