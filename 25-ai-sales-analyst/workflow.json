        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n\"model\": \"llama-3.3-70b-versatile\",\n\"messages\": [\n{\n\"role\": \"system\",\n\"content\": \"Ти досвідчений бізнес-аналітик. Аналізуй дані продажів і давай 3 конкретні рекомендації для збільшення виручки. Відповідай чітко і по суті.\"\n},\n{\n\"role\": \"user\",\n\"content\": \"={{ $json.report_text.replace(/\\\\n/g, ' ') }}\"\n}\n],\n\"temperature\": 0.7,\n\"max_tokens\": 1024\n}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        -32,
        0
      ],
      "id": "c303a206-32cc-4daf-8d1f-39061990c548",
      "name": "Groq AI Analysis",
      "credentials": {
        "httpHeaderAuth": {
          "id": "YOUR_GROQ_CREDENTIAL_ID",
          "name": "Groq API"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst rows = items.map(i => i.json);\n\n// Загальна виручка\nconst totalRevenue = rows.reduce((sum, r) => sum + parseFloat(r.total_eur || 0), 0);\n\n// Групування по продуктах\nconst byProduct = {};\nrows.forEach(r => {\nconst name = r.product_name || 'Unknown';\nif (!byProduct[name]) byProduct[name] = { revenue: 0, qty: 0 };\nbyProduct[name].revenue += parseFloat(r.total_eur || 0);\nbyProduct[name].qty += parseInt(r.quantity || 0);\n});\n\n// Сортування\nconst sorted = Object.entries(byProduct)\n.map(([name, data]) => ({ name, ...data }))\n.sort((a, b) => b.revenue - a.revenue);\n\nconst top3 = sorted.slice(0, 3);\nconst bottom3 = sorted.slice(-3).reverse();\n\nconst today = new Date();\nconst weekStart = new Date(today);\nweekStart.setDate(today.getDate() - 7);\nconst fmt = d => d.toISOString().split('T')[0];\n\nconst topList = top3.map(p => p.name + ' (' + p.revenue.toFixed(2) + ' EUR)').join(', ');\nconst bottomList = bottom3.map(p => p.name + ' (' + p.revenue.toFixed(2) + ' EUR)').join(', ');\n\nconst report_text = 'Тижневий звіт (' + fmt(weekStart) + ' — ' + fmt(today) + '). ' +\n'Загальна виручка: ' + totalRevenue.toFixed(2) + ' EUR. ' +\n'Кількість замовлень: ' + rows.length + '. ' +\n'ТОП-3 продукти: ' + topList + '. ' +\n'Аутсайдери: ' + bottomList + '.';\n\nreturn [{\njson: {\ntotal_revenue: totalRevenue.toFixed(2),\ntop3,\nbottom3,\nweek_start: fmt(weekStart),\nweek_end: fmt(today),\ntotal_orders: rows.length,\ntop_product: top3[0]?.name || 'N/A',\nreport_text\n}\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -240,
        0
      ],
